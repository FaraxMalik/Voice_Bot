# ─── Voice Agent Configuration ───

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000

# Ollama (LLM)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b

# STT (faster-whisper)
STT_MODEL_SIZE=small
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8

# TTS (XTTS v2)
TTS_MODEL_DIR=/app/models/tts
TTS_REFERENCE_WAV=/app/models/tts/reference.wav
TTS_DEVICE=cpu
COQUI_TOS_AGREED=1

# Agent behavior
AGENT_SYSTEM_PROMPT=You are a professional, helpful call agent. Respond concisely in 1-3 sentences. Be friendly and clear.
AGENT_MAX_HISTORY=10
